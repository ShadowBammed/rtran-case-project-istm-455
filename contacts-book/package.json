{
  "name": "contacts-book",
  "version": "1.0.0",
  "description": "Minimal contacts-book REST API with CRUD, SQLite, HTTPS",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node src/app.js",
    "gen-cert": "bash gen-cert.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docker:build": "docker build -t contacts-book .",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "express": "^5.2.1"
  },
  "devDependencies": {
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  }
}
